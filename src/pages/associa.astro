---
import GameLayout from '../layouts/GameLayout.astro';
import Header from '../components/Header.astro';
---

<GameLayout title="Associa - Collega le Coppie">
    <div class="app-container">
        <Header title="Associa">
            <div class="score-display"><span id="matchedCount">0</span> / <span id="totalCount">0</span></div>
            <button class="btn btn-reset" id="resetBtn" aria-label="Ricomincia">
                <svg viewBox="0 0 24 24"><path d="M17.65 6.35A7.958 7.958 0 0012 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0112 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
            </button>
        </Header>

        <main class="game-container">
            <div class="game-area">
                <div class="items-column" id="leftColumn"></div>
                <div class="items-column" id="rightColumn"></div>
            </div>
        </main>

        <div class="confetti-container" id="confettiContainer"></div>
        <div class="modal-overlay" id="winModal">
            <div class="modal-content">
                <h2>Fantastico!</h2>
                <p>Hai collegato tutte le coppie!</p>
                <button class="modal-btn" id="playAgainBtn">Gioca Ancora</button>
            </div>
        </div>
    </div>
</GameLayout>

<style>
    .score-display {
        background: rgba(255,255,255,0.2);
        padding: 8px 15px;
        border-radius: 20px;
        color: white;
        font-weight: 600;
    }

    .game-container {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 15px;
    }

    .game-area {
        display: flex;
        justify-content: space-around;
        align-items: center;
        width: 100%;
        max-width: 500px;
        gap: 20px;
    }

    .items-column {
        display: flex;
        flex-direction: column;
        gap: 12px;
        align-items: center;
    }

    :global(.assoc-item) {
        width: 100px;
        height: 100px;
        background: white;
        border-radius: 18px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        border: 4px solid transparent;
    }

    :global(.assoc-item:active) {
        transform: scale(0.95);
    }

    :global(.assoc-item.selected) {
        border-color: #3b82f6;
        transform: scale(1.05);
        box-shadow: 0 6px 25px rgba(59, 130, 246, 0.4);
    }

    :global(.assoc-item.matched) {
        opacity: 0.4;
        pointer-events: none;
        transform: scale(0.9);
    }

    :global(.assoc-item.wrong) {
        border-color: #ef4444;
        animation: shake 0.4s ease;
    }

    :global(.assoc-item .item-emoji) {
        font-size: 2.5rem;
        line-height: 1;
    }

    :global(.assoc-item .item-label) {
        font-size: 0.7rem;
        font-weight: 600;
        color: #6b7280;
        text-align: center;
    }

    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-6px); }
        75% { transform: translateX(6px); }
    }

    .confetti-container {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        pointer-events: none; z-index: 1000;
    }

    :global(.confetti) {
        position: absolute; width: 10px; height: 10px;
        animation: confettiFall 1.5s ease-out forwards;
    }

    @keyframes confettiFall {
        0% { opacity: 1; transform: translateY(0) rotate(0); }
        100% { opacity: 0; transform: translateY(200px) rotate(720deg); }
    }

    .modal-content { text-align: center; padding: 40px; }
    .modal-content h2 { font-size: 2rem; margin-bottom: 15px; color: #1f2937; }
    .modal-content p { font-size: 1.2rem; color: #6b7280; margin-bottom: 25px; }

    @media (max-width: 400px) {
        :global(.assoc-item) { width: 80px; height: 80px; border-radius: 14px; }
        :global(.assoc-item .item-emoji) { font-size: 2rem; }
        .items-column { gap: 10px; }
        .game-area { gap: 15px; }
    }

    @media (min-width: 768px) {
        :global(.assoc-item) { width: 120px; height: 120px; border-radius: 22px; }
        :global(.assoc-item .item-emoji) { font-size: 3.2rem; }
        :global(.assoc-item .item-label) { font-size: 0.85rem; }
        .items-column { gap: 15px; }
        .game-area { max-width: 600px; gap: 30px; }
    }

    @media (orientation: landscape) and (max-height: 500px) {
        :global(.assoc-item) { width: 70px; height: 70px; border-radius: 12px; }
        :global(.assoc-item .item-emoji) { font-size: 1.8rem; }
        :global(.assoc-item .item-label) { font-size: 0.6rem; }
        .items-column { gap: 6px; }
        .game-container { padding: 8px; }
    }
</style>

<script>
    interface Pair {
        left: { emoji: string; label: string };
        right: { emoji: string; label: string };
        id: string;
    }

    const ALL_PAIRS: Pair[] = [
        { id: 'dog', left: { emoji: '🐶', label: 'Cane' }, right: { emoji: '🦴', label: 'Osso' } },
        { id: 'bee', left: { emoji: '🐝', label: 'Ape' }, right: { emoji: '🌸', label: 'Fiore' } },
        { id: 'rain', left: { emoji: '🌧️', label: 'Pioggia' }, right: { emoji: '☂️', label: 'Ombrello' } },
        { id: 'pen', left: { emoji: '✏️', label: 'Matita' }, right: { emoji: '📓', label: 'Quaderno' } },
        { id: 'key', left: { emoji: '🔑', label: 'Chiave' }, right: { emoji: '🔒', label: 'Lucchetto' } },
        { id: 'bird', left: { emoji: '🐦', label: 'Uccello' }, right: { emoji: '🪺', label: 'Nido' } },
        { id: 'fire', left: { emoji: '🔥', label: 'Fuoco' }, right: { emoji: '🧯', label: 'Estintore' } },
        { id: 'moon', left: { emoji: '🌙', label: 'Luna' }, right: { emoji: '⭐', label: 'Stelle' } },
        { id: 'chef', left: { emoji: '👨‍🍳', label: 'Cuoco' }, right: { emoji: '🍳', label: 'Padella' } },
        { id: 'fish', left: { emoji: '🐟', label: 'Pesce' }, right: { emoji: '🌊', label: 'Mare' } },
        { id: 'baby', left: { emoji: '👶', label: 'Bimbo' }, right: { emoji: '🍼', label: 'Biberon' } },
        { id: 'cat', left: { emoji: '🐱', label: 'Gatto' }, right: { emoji: '🧶', label: 'Gomitolo' } },
    ];

    const PAIRS_PER_ROUND = 5;
    let gamePairs: Pair[] = [];
    let selectedLeft: { el: HTMLElement; pairId: string } | null = null;
    let matched = 0;
    let locked = false;

    const leftColumn = document.getElementById('leftColumn')!;
    const rightColumn = document.getElementById('rightColumn')!;
    const matchedCount = document.getElementById('matchedCount')!;
    const totalCount = document.getElementById('totalCount')!;
    const confettiContainer = document.getElementById('confettiContainer')!;
    const winModal = document.getElementById('winModal')!;

    function shuffle<T>(arr: T[]): T[] {
        const a = [...arr];
        for (let i = a.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [a[i], a[j]] = [a[j], a[i]];
        }
        return a;
    }

    function initGame(): void {
        matched = 0;
        selectedLeft = null;
        locked = false;
        winModal.classList.remove('active');
        gamePairs = shuffle(ALL_PAIRS).slice(0, PAIRS_PER_ROUND);
        matchedCount.textContent = '0';
        totalCount.textContent = String(PAIRS_PER_ROUND);

        leftColumn.innerHTML = '';
        rightColumn.innerHTML = '';

        const shuffledLeft = shuffle([...gamePairs]);
        const shuffledRight = shuffle([...gamePairs]);

        shuffledLeft.forEach(pair => {
            const el = createItem(pair.left, pair.id, 'left');
            leftColumn.appendChild(el);
        });

        shuffledRight.forEach(pair => {
            const el = createItem(pair.right, pair.id, 'right');
            rightColumn.appendChild(el);
        });
    }

    function createItem(data: { emoji: string; label: string }, pairId: string, side: 'left' | 'right'): HTMLElement {
        const el = document.createElement('div');
        el.className = 'assoc-item';
        el.dataset.pairId = pairId;
        el.dataset.side = side;
        el.innerHTML = `<span class="item-emoji">${data.emoji}</span><span class="item-label">${data.label}</span>`;

        el.addEventListener('click', () => handleTap(el, pairId, side));
        el.addEventListener('touchend', (e) => {
            e.preventDefault();
            handleTap(el, pairId, side);
        }, { passive: false });

        return el;
    }

    function handleTap(el: HTMLElement, pairId: string, side: 'left' | 'right'): void {
        if (locked || el.classList.contains('matched')) return;

        if (side === 'left') {
            if (selectedLeft?.el === el) {
                el.classList.remove('selected');
                selectedLeft = null;
                return;
            }
            if (selectedLeft) selectedLeft.el.classList.remove('selected');
            el.classList.add('selected');
            selectedLeft = { el, pairId };
        } else if (side === 'right' && selectedLeft) {
            locked = true;
            if (pairId === selectedLeft.pairId) {
                selectedLeft.el.classList.remove('selected');
                selectedLeft.el.classList.add('matched');
                el.classList.add('matched');
                matched++;
                matchedCount.textContent = String(matched);
                createConfetti(el);
                selectedLeft = null;
                locked = false;
                if (matched === PAIRS_PER_ROUND) {
                    setTimeout(() => winModal.classList.add('active'), 500);
                }
            } else {
                el.classList.add('wrong');
                selectedLeft.el.classList.add('wrong');
                const prevLeft = selectedLeft.el;
                setTimeout(() => {
                    el.classList.remove('wrong');
                    prevLeft.classList.remove('wrong');
                    prevLeft.classList.remove('selected');
                    selectedLeft = null;
                    locked = false;
                }, 500);
            }
        }
    }

    function createConfetti(el: HTMLElement): void {
        const r = el.getBoundingClientRect();
        const cx = r.left + r.width / 2, cy = r.top + r.height / 2;
        const colors = ['#ef4444', '#3b82f6', '#22c55e', '#fbbf24', '#ec4899', '#8b5cf6'];
        for (let i = 0; i < 12; i++) {
            const c = document.createElement('div');
            c.className = 'confetti';
            c.style.left = `${cx + (Math.random() - 0.5) * 80}px`;
            c.style.top = `${cy}px`;
            c.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
            confettiContainer.appendChild(c);
            setTimeout(() => c.remove(), 1500);
        }
    }

    document.getElementById('resetBtn')!.addEventListener('click', initGame);
    document.getElementById('playAgainBtn')!.addEventListener('click', initGame);
    initGame();
</script>
