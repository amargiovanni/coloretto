---
import GameLayout from '../layouts/GameLayout.astro';
import Header from '../components/Header.astro';
---

<GameLayout title="Somme - Addizioni Facili">
    <div class="app-container">
        <Header title="Somme">
            <div class="score-display"><span id="matchedCount">0</span> / <span id="totalCount">0</span></div>
            <button class="btn btn-reset" id="resetBtn" aria-label="Ricomincia">
                <svg viewBox="0 0 24 24"><path d="M17.65 6.35A7.958 7.958 0 0012 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0112 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
            </button>
        </Header>

        <main class="game-container">
            <div class="equation" id="equation"></div>
            <div class="choices-row" id="choicesRow"></div>
        </main>

        <div class="confetti-container" id="confettiContainer"></div>
        <div class="modal-overlay" id="winModal">
            <div class="modal-content">
                <h2>Bravissimo!</h2>
                <p>Hai fatto tutte le somme!</p>
                <button class="modal-btn" id="playAgainBtn">Gioca Ancora</button>
            </div>
        </div>
    </div>
</GameLayout>

<style>
    .score-display {
        background: rgba(255,255,255,0.2);
        padding: 8px 15px;
        border-radius: 20px;
        color: white;
        font-weight: 600;
    }

    .game-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 15px;
        gap: 30px;
        overflow: hidden;
    }

    .equation {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
    }

    :global(.eq-group) {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        justify-content: center;
        align-items: center;
        background: rgba(255,255,255,0.15);
        padding: 12px 16px;
        border-radius: 18px;
        min-width: 60px;
        min-height: 50px;
    }

    :global(.eq-emoji) {
        font-size: 2rem;
    }

    :global(.eq-operator) {
        font-size: 2.5rem;
        font-weight: 800;
        color: white;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        min-width: 40px;
        text-align: center;
    }

    :global(.eq-result) {
        background: rgba(255,255,255,0.3);
        border: 3px dashed rgba(255,255,255,0.6);
        padding: 12px 20px;
        border-radius: 18px;
        font-size: 2rem;
        font-weight: 800;
        color: white;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        min-width: 60px;
        text-align: center;
    }

    :global(.eq-result.filled) {
        background: rgba(74,222,128,0.4);
        border-style: solid;
        border-color: #4ade80;
    }

    .choices-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: center;
    }

    :global(.sum-choice) {
        width: 70px;
        height: 70px;
        background: white;
        border: 4px solid transparent;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        font-weight: 700;
        color: #1f2937;
        cursor: pointer;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        transition: transform 0.15s ease, border-color 0.2s ease;
    }

    :global(.sum-choice:active) {
        transform: scale(0.92);
    }

    :global(.sum-choice.correct) {
        border-color: #4ade80;
        background: #ecfdf5;
    }

    :global(.sum-choice.wrong) {
        animation: shake 0.4s ease;
    }

    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-8px); }
        75% { transform: translateX(8px); }
    }

    .confetti-container {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        pointer-events: none; z-index: 1000;
    }

    :global(.confetti) {
        position: absolute; width: 10px; height: 10px;
        animation: confettiFall 1.5s ease-out forwards;
    }

    @keyframes confettiFall {
        0% { opacity: 1; transform: translateY(0) rotate(0); }
        100% { opacity: 0; transform: translateY(200px) rotate(720deg); }
    }

    .modal-content { text-align: center; padding: 40px; }
    .modal-content h2 { font-size: 2rem; margin-bottom: 15px; color: #1f2937; }
    .modal-content p { font-size: 1.2rem; color: #6b7280; margin-bottom: 25px; }

    @media (max-width: 400px) {
        :global(.eq-emoji) { font-size: 1.5rem; }
        :global(.eq-operator) { font-size: 2rem; min-width: 30px; }
        :global(.eq-group) { padding: 8px 12px; border-radius: 14px; }
        :global(.eq-result) { font-size: 1.5rem; padding: 8px 16px; }
        :global(.sum-choice) { width: 58px; height: 58px; font-size: 1.5rem; }
        .equation { gap: 8px; }
        .choices-row { gap: 8px; }
        .game-container { gap: 20px; }
    }

    @media (min-width: 768px) {
        :global(.eq-emoji) { font-size: 2.5rem; }
        :global(.eq-operator) { font-size: 3rem; }
        :global(.eq-group) { padding: 15px 20px; border-radius: 22px; }
        :global(.eq-result) { font-size: 2.5rem; padding: 15px 25px; }
        :global(.sum-choice) { width: 85px; height: 85px; font-size: 2.2rem; }
        .equation { gap: 15px; }
        .choices-row { gap: 15px; }
        .game-container { gap: 40px; }
    }

    @media (orientation: landscape) and (max-height: 500px) {
        .game-container { gap: 12px; padding: 8px; }
        :global(.eq-emoji) { font-size: 1.3rem; }
        :global(.eq-operator) { font-size: 1.5rem; min-width: 25px; }
        :global(.eq-group) { padding: 6px 10px; border-radius: 10px; }
        :global(.eq-result) { font-size: 1.3rem; padding: 6px 12px; }
        :global(.sum-choice) { width: 48px; height: 48px; font-size: 1.2rem; }
        .equation { gap: 6px; }
        .choices-row { gap: 6px; }
    }
</style>

<script>
    const EMOJIS = ['🍎', '🍌', '⭐', '🌸', '🐟', '🦋', '❤️', '🔵'];
    const NUM_ROUNDS = 8;
    let currentRound = 0;
    let score = 0;
    let locked = false;

    const equation = document.getElementById('equation')!;
    const choicesRow = document.getElementById('choicesRow')!;
    const matchedCount = document.getElementById('matchedCount')!;
    const totalCount = document.getElementById('totalCount')!;
    const confettiContainer = document.getElementById('confettiContainer')!;
    const winModal = document.getElementById('winModal')!;

    function shuffle<T>(arr: T[]): T[] {
        const a = [...arr];
        for (let i = a.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [a[i], a[j]] = [a[j], a[i]];
        }
        return a;
    }

    function initGame(): void {
        score = 0;
        currentRound = 0;
        locked = false;
        winModal.classList.remove('active');
        matchedCount.textContent = '0';
        totalCount.textContent = String(NUM_ROUNDS);
        showRound();
    }

    function showRound(): void {
        if (currentRound >= NUM_ROUNDS) {
            setTimeout(() => winModal.classList.add('active'), 500);
            return;
        }

        locked = false;
        const a = Math.floor(Math.random() * 4) + 1;
        const b = Math.floor(Math.random() * 4) + 1;
        const answer = a + b;
        const emoji = EMOJIS[Math.floor(Math.random() * EMOJIS.length)];

        equation.innerHTML = '';

        const groupA = document.createElement('div');
        groupA.className = 'eq-group';
        for (let i = 0; i < a; i++) {
            const e = document.createElement('span');
            e.className = 'eq-emoji';
            e.textContent = emoji;
            groupA.appendChild(e);
        }
        equation.appendChild(groupA);

        const plus = document.createElement('span');
        plus.className = 'eq-operator';
        plus.textContent = '+';
        equation.appendChild(plus);

        const groupB = document.createElement('div');
        groupB.className = 'eq-group';
        for (let i = 0; i < b; i++) {
            const e = document.createElement('span');
            e.className = 'eq-emoji';
            e.textContent = emoji;
            groupB.appendChild(e);
        }
        equation.appendChild(groupB);

        const equals = document.createElement('span');
        equals.className = 'eq-operator';
        equals.textContent = '=';
        equation.appendChild(equals);

        const result = document.createElement('div');
        result.className = 'eq-result';
        result.id = 'resultSlot';
        result.textContent = '?';
        equation.appendChild(result);

        const distractors = new Set<number>();
        distractors.add(answer);
        while (distractors.size < 4) {
            const d = answer + Math.floor(Math.random() * 5) - 2;
            if (d > 0 && d !== answer) distractors.add(d);
        }

        choicesRow.innerHTML = '';
        shuffle([...distractors]).forEach(num => {
            const btn = document.createElement('button');
            btn.className = 'sum-choice';
            btn.textContent = String(num);
            btn.addEventListener('click', () => handleTap(num, btn, answer));
            btn.addEventListener('touchend', (e) => {
                e.preventDefault();
                handleTap(num, btn, answer);
            }, { passive: false });
            choicesRow.appendChild(btn);
        });
    }

    function handleTap(num: number, btn: HTMLButtonElement, answer: number): void {
        if (locked) return;

        if (num === answer) {
            locked = true;
            btn.classList.add('correct');
            const result = document.getElementById('resultSlot')!;
            result.textContent = String(answer);
            result.classList.add('filled');
            score++;
            matchedCount.textContent = String(score);
            createConfetti(result);
            currentRound++;
            setTimeout(showRound, 900);
        } else {
            btn.classList.add('wrong');
            setTimeout(() => btn.classList.remove('wrong'), 400);
        }
    }

    function createConfetti(el: HTMLElement): void {
        const r = el.getBoundingClientRect();
        const cx = r.left + r.width / 2, cy = r.top + r.height / 2;
        const colors = ['#ef4444', '#3b82f6', '#22c55e', '#fbbf24', '#ec4899', '#8b5cf6'];
        for (let i = 0; i < 12; i++) {
            const c = document.createElement('div');
            c.className = 'confetti';
            c.style.left = `${cx + (Math.random() - 0.5) * 80}px`;
            c.style.top = `${cy}px`;
            c.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
            confettiContainer.appendChild(c);
            setTimeout(() => c.remove(), 1500);
        }
    }

    document.getElementById('resetBtn')!.addEventListener('click', initGame);
    document.getElementById('playAgainBtn')!.addEventListener('click', initGame);
    initGame();
</script>
