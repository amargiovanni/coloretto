---
import GameLayout from '../layouts/GameLayout.astro';
import GameCard from '../components/GameCard.astro';
---

<GameLayout title="Giochi per Bambini">
    <div class="app-container">
        <header class="header header-center">
            <h1>Giochi per Bambini</h1>
        </header>

        <main class="games-container allow-scroll">
            <div class="games-grid">
                <GameCard href="/bolle" title="Schiaccia le Bolle" colorClass="game-bolle">
                    <svg viewBox="0 0 24 24">
                        <circle cx="8" cy="9" r="4.5"/>
                        <circle cx="17" cy="14" r="3.5"/>
                        <circle cx="14" cy="6" r="2"/>
                    </svg>
                </GameCard>

                <GameCard href="/coloretto" title="Coloretto" colorClass="game-coloretto">
                    <svg viewBox="0 0 24 24">
                        <path d="M7 14c-1.66 0-3 1.34-3 3 0 1.31-1.16 2-2 2 .92 1.22 2.49 2 4 2 2.21 0 4-1.79 4-4 0-1.66-1.34-3-3-3zm13.71-9.37l-1.34-1.34a.996.996 0 00-1.41 0L9 12.25 11.75 15l8.96-8.96a.996.996 0 000-1.41z"/>
                    </svg>
                </GameCard>

                <GameCard href="/memory" title="Memory Animali" colorClass="game-memory">
                    <svg viewBox="0 0 24 24">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14z"/>
                        <path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zm0 8c-1.65 0-3-1.35-3-3s1.35-3 3-3 3 1.35 3 3-1.35 3-3 3z"/>
                    </svg>
                </GameCard>

                <GameCard href="/forme" title="Trova le Forme" colorClass="game-forme">
                    <svg viewBox="0 0 24 24">
                        <path d="M12 2L2 19h20L12 2zm0 4l6.5 11h-13L12 6z"/>
                    </svg>
                </GameCard>

                <GameCard href="/conta" title="Conta gli Oggetti" colorClass="game-conta">
                    <svg viewBox="0 0 24 24">
                        <path d="M5 13h3v6H5v-6zm7-9h3v15h-3V4zm7 4h3v11h-3V8z"/>
                    </svg>
                </GameCard>

                <GameCard href="/vesti" title="Vesti l'Animale" colorClass="game-vesti">
                    <svg viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
                        <circle cx="9" cy="10" r="1.5"/>
                        <circle cx="15" cy="10" r="1.5"/>
                        <path d="M12 17c2.21 0 4-1.79 4-4h-8c0 2.21 1.79 4 4 4z"/>
                    </svg>
                </GameCard>

                <GameCard href="/puzzle" title="Puzzle Semplici" colorClass="game-puzzle">
                    <svg viewBox="0 0 24 24">
                        <path d="M20.5 11H19V7c0-1.1-.9-2-2-2h-4V3.5C13 2.12 11.88 1 10.5 1S8 2.12 8 3.5V5H4c-1.1 0-2 .9-2 2v3.8h1.5c1.38 0 2.5 1.12 2.5 2.5S4.88 15.8 3.5 15.8H2V19c0 1.1.9 2 2 2h3.8v-1.5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5V21H17c1.1 0 2-.9 2-2v-4h1.5c1.38 0 2.5-1.12 2.5-2.5S21.88 11 20.5 11z"/>
                    </svg>
                </GameCard>

                <GameCard href="/ordina" title="Ordina i Numeri" colorClass="game-ordina">
                    <svg viewBox="0 0 24 24">
                        <path d="M3 18h3v-2H3v2zm0-5h6v-2H3v2zm0-7v2h9V6H3zm14 12.5v-2.5h2v-2h-2V11.5l-3 3.5 3 3.5zM13 16h-3v2h3v-2zm4-8.5V10h-2v2h2v2.5l3-3.5-3-3.5zM13 10h3V8h-3v2z"/>
                    </svg>
                </GameCard>

                <GameCard href="/confronta" title="Più o Meno?" colorClass="game-confronta">
                    <svg viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H7v-2h4v2zm6-4H7v-2h10v2zm0-4H7V6h10v2z"/>
                    </svg>
                </GameCard>

                <GameCard href="/abc" title="ABC" colorClass="game-abc">
                    <svg viewBox="0 0 24 24">
                        <path d="M5 17l3.5-10h1l3.5 10h-1.2l-.9-2.7H7.1L6.2 17H5zm2.5-3.8h3l-1.5-4.5-1.5 4.5zM15 17V7h1.1v4.3h.1L19.8 7H21l-3.5 4.1L21.2 17H20l-3.2-4.8-1.8 2.1V17H15z"/>
                    </svg>
                </GameCard>

                <GameCard href="/disegna" title="Disegna" colorClass="game-disegna">
                    <svg viewBox="0 0 24 24">
                        <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a.996.996 0 000-1.41l-2.34-2.34a.996.996 0 00-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                    </svg>
                </GameCard>

                <GameCard href="/intruso" title="Trova l'Intruso" colorClass="game-intruso">
                    <svg viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                    </svg>
                </GameCard>

                <GameCard href="/associa" title="Associa" colorClass="game-associa">
                    <svg viewBox="0 0 24 24">
                        <path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/>
                    </svg>
                </GameCard>

                <GameCard href="/stagioni" title="Le Stagioni" colorClass="game-stagioni">
                    <svg viewBox="0 0 24 24">
                        <path d="M6.76 4.84l-1.8-1.79-1.41 1.41 1.79 1.79 1.42-1.41zM4 10.5H1v2h3v-2zm9-9.95h-2V3.5h2V.55zm7.45 3.91l-1.41-1.41-1.79 1.79 1.41 1.41 1.79-1.79zm-3.21 13.7l1.79 1.8 1.41-1.41-1.8-1.79-1.4 1.4zM20 10.5v2h3v-2h-3zm-8-5c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm-1 16.95h2V19.5h-2v2.95zm-7.45-3.91l1.41 1.41 1.79-1.8-1.41-1.41-1.79 1.8z"/>
                    </svg>
                </GameCard>

<GameCard href="/ombre" title="Ombre" colorClass="game-ombre">
                    <svg viewBox="0 0 24 24">
                        <path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9zm0 16c-3.86 0-7-3.14-7-7s3.14-7 7-7 7 3.14 7 7-3.14 7-7 7z"/>
                        <path d="M12 5v14c3.86 0 7-3.14 7-7s-3.14-7-7-7z"/>
                    </svg>
                </GameCard>

                <GameCard href="/somme" title="Somme" colorClass="game-somme">
                    <svg viewBox="0 0 24 24">
                        <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                    </svg>
                </GameCard>
            </div>
        </main>
    </div>
</GameLayout>

<style>
    .header-center {
        justify-content: center;
        padding: 20px 15px;
    }

    .header-center h1 {
        font-size: 2rem;
        text-align: center;
    }

    .games-container {
        flex: 1;
        display: flex;
        align-items: safe center;
        justify-content: center;
        padding: 20px;
        overflow: auto;
        -webkit-overflow-scrolling: touch;
    }

    .games-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        max-width: 500px;
        width: 100%;
    }

    @media (max-width: 400px) {
        .header-center h1 {
            font-size: 1.5rem;
        }
        .games-grid {
            gap: 15px;
        }
    }

    @media (min-width: 768px) {
        .header-center {
            padding: 20px 25px;
        }
        .header-center h1 {
            font-size: 2.5rem;
        }
        .games-grid {
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            max-width: 750px;
        }
    }

    @media (min-width: 1024px) {
        .games-grid {
            gap: 25px;
            max-width: 850px;
        }
    }

    @media (orientation: landscape) and (max-height: 500px) {
        .header-center {
            padding: 8px 15px;
        }
        .header-center h1 {
            font-size: 1.2rem;
        }
        .games-container {
            padding: 10px;
        }
        .games-grid {
            grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
            gap: 10px;
            max-width: 1200px;
        }
    }
</style>
