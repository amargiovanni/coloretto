---
import GameLayout from '../layouts/GameLayout.astro';
import Header from '../components/Header.astro';
---

<GameLayout title="ABC - Impara l'Alfabeto">
    <div class="app-container">
        <Header title="ABC">
            <div class="score-display"><span id="matchedCount">0</span> / <span id="totalCount">0</span></div>
            <button class="btn btn-reset" id="resetBtn" aria-label="Ricomincia">
                <svg viewBox="0 0 24 24"><path d="M17.65 6.35A7.958 7.958 0 0012 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0112 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
            </button>
        </Header>

        <main class="game-container">
            <div class="letter-display" id="letterDisplay">
                <div class="letter-big" id="targetLetter">A</div>
                <div class="letter-hint" id="letterHint">Trova la lettera A</div>
            </div>
            <div class="letters-grid" id="lettersGrid"></div>
        </main>

        <div class="confetti-container" id="confettiContainer"></div>
        <div class="modal-overlay" id="winModal">
            <div class="modal-content">
                <h2>Bravissimo!</h2>
                <p>Hai trovato tutte le lettere!</p>
                <button class="modal-btn" id="playAgainBtn">Gioca Ancora</button>
            </div>
        </div>
    </div>
</GameLayout>

<style>
    .score-display {
        background: rgba(255,255,255,0.2);
        padding: 8px 15px;
        border-radius: 20px;
        color: white;
        font-weight: 600;
    }

    .game-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 15px;
        gap: 15px;
        overflow: hidden;
    }

    .letter-display {
        text-align: center;
    }

    .letter-big {
        font-size: 5rem;
        font-weight: 800;
        color: white;
        text-shadow: 3px 3px 6px rgba(0,0,0,0.3);
        line-height: 1;
    }

    .letter-hint {
        color: rgba(255,255,255,0.8);
        font-size: 1.1rem;
        font-weight: 600;
        margin-top: 5px;
    }

    .letters-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        max-width: 400px;
        width: 100%;
    }

    :global(.letter-btn) {
        aspect-ratio: 1;
        background: white;
        border: none;
        border-radius: 18px;
        font-size: 2rem;
        font-weight: 700;
        color: #1f2937;
        cursor: pointer;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    :global(.letter-btn:active) {
        transform: scale(0.92);
    }

    :global(.letter-btn.correct) {
        background: #4ade80;
        color: white;
        pointer-events: none;
    }

    :global(.letter-btn.wrong) {
        animation: shake 0.4s ease;
    }

    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-8px); }
        75% { transform: translateX(8px); }
    }

    .confetti-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1000;
    }

    :global(.confetti) {
        position: absolute;
        width: 10px;
        height: 10px;
        animation: confettiFall 1.5s ease-out forwards;
    }

    @keyframes confettiFall {
        0% { opacity: 1; transform: translateY(0) rotate(0); }
        100% { opacity: 0; transform: translateY(200px) rotate(720deg); }
    }

    .modal-content {
        text-align: center;
        padding: 40px;
    }

    .modal-content h2 {
        font-size: 2rem;
        margin-bottom: 15px;
        color: #1f2937;
    }

    .modal-content p {
        font-size: 1.2rem;
        color: #6b7280;
        margin-bottom: 25px;
    }

    @media (max-width: 400px) {
        .letter-big {
            font-size: 3.5rem;
        }
        .letter-hint {
            font-size: 0.95rem;
        }
        .letters-grid {
            gap: 10px;
        }
        :global(.letter-btn) {
            font-size: 1.5rem;
            border-radius: 14px;
        }
    }

    @media (min-width: 768px) {
        .letter-big {
            font-size: 6rem;
        }
        .letter-hint {
            font-size: 1.3rem;
        }
        .letters-grid {
            gap: 15px;
            max-width: 500px;
        }
        :global(.letter-btn) {
            font-size: 2.5rem;
            border-radius: 22px;
        }
    }

    @media (orientation: landscape) and (max-height: 500px) {
        .game-container {
            flex-direction: row;
            gap: 20px;
            padding: 10px;
        }
        .letter-big {
            font-size: 3rem;
        }
        .letter-hint {
            font-size: 0.85rem;
        }
        .letters-grid {
            max-width: 350px;
            gap: 8px;
        }
        :global(.letter-btn) {
            font-size: 1.3rem;
            border-radius: 12px;
        }
    }
</style>

<script>
    const ALPHABET = 'ABCDEFGHIJKLMNOPQRSTUVZ'.split('');
    const ROUND_SIZE = 8;
    const GRID_SIZE = 8;

    const LETTER_COLORS: Record<string, string> = {
        A: '#ef4444', B: '#3b82f6', C: '#22c55e', D: '#f59e0b',
        E: '#8b5cf6', F: '#ec4899', G: '#14b8a6', H: '#f97316',
        I: '#6366f1', L: '#d946ef', M: '#06b6d4', N: '#84cc16',
        O: '#ef4444', P: '#3b82f6', Q: '#22c55e', R: '#f59e0b',
        S: '#8b5cf6', T: '#ec4899', U: '#14b8a6', V: '#f97316',
        Z: '#6366f1'
    };

    let targetLetters: string[] = [];
    let currentIndex = 0;
    let matched = 0;

    const targetLetterEl = document.getElementById('targetLetter')!;
    const letterHint = document.getElementById('letterHint')!;
    const lettersGrid = document.getElementById('lettersGrid')!;
    const matchedCount = document.getElementById('matchedCount')!;
    const totalCount = document.getElementById('totalCount')!;
    const confettiContainer = document.getElementById('confettiContainer')!;
    const winModal = document.getElementById('winModal')!;

    function shuffle<T>(arr: T[]): T[] {
        const a = [...arr];
        for (let i = a.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [a[i], a[j]] = [a[j], a[i]];
        }
        return a;
    }

    function initGame(): void {
        matched = 0;
        currentIndex = 0;
        winModal.classList.remove('active');

        targetLetters = shuffle(ALPHABET).slice(0, ROUND_SIZE);
        matchedCount.textContent = '0';
        totalCount.textContent = String(ROUND_SIZE);

        showNextLetter();
    }

    function showNextLetter(): void {
        if (currentIndex >= targetLetters.length) {
            setTimeout(() => winModal.classList.add('active'), 500);
            return;
        }

        const target = targetLetters[currentIndex];
        targetLetterEl.textContent = target;
        targetLetterEl.style.color = LETTER_COLORS[target] || 'white';
        letterHint.textContent = `Trova la lettera ${target}`;

        const distractors = shuffle(ALPHABET.filter(l => l !== target)).slice(0, GRID_SIZE - 1);
        const gridLetters = shuffle([target, ...distractors]);

        lettersGrid.innerHTML = '';
        gridLetters.forEach(letter => {
            const btn = document.createElement('button');
            btn.className = 'letter-btn';
            btn.textContent = letter;
            btn.style.color = LETTER_COLORS[letter] || '#1f2937';
            btn.addEventListener('click', () => handleTap(letter, btn));
            btn.addEventListener('touchend', (e) => {
                e.preventDefault();
                handleTap(letter, btn);
            }, { passive: false });
            lettersGrid.appendChild(btn);
        });
    }

    function handleTap(letter: string, btn: HTMLButtonElement): void {
        if (btn.classList.contains('correct')) return;

        const target = targetLetters[currentIndex];
        if (letter === target) {
            btn.classList.add('correct');
            matched++;
            matchedCount.textContent = String(matched);
            currentIndex++;
            createConfetti(btn);
            setTimeout(showNextLetter, 600);
        } else {
            btn.classList.add('wrong');
            setTimeout(() => btn.classList.remove('wrong'), 400);
        }
    }

    function createConfetti(el: HTMLElement): void {
        const r = el.getBoundingClientRect();
        const cx = r.left + r.width / 2;
        const cy = r.top + r.height / 2;
        const colors = ['#ef4444', '#3b82f6', '#22c55e', '#fbbf24', '#ec4899', '#8b5cf6'];
        for (let i = 0; i < 12; i++) {
            const c = document.createElement('div');
            c.className = 'confetti';
            c.style.left = `${cx + (Math.random() - 0.5) * 80}px`;
            c.style.top = `${cy}px`;
            c.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
            confettiContainer.appendChild(c);
            setTimeout(() => c.remove(), 1500);
        }
    }

    document.getElementById('resetBtn')!.addEventListener('click', initGame);
    document.getElementById('playAgainBtn')!.addEventListener('click', initGame);
    initGame();
</script>
